# ============================================================================
# Synapse AI Gateway — Backend configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values:   cp .env.example .env
#
# Every variable is read in backend/config.py. All values shown below are the
# built-in DEFAULTS — you only need to set the ones you want to change.
# REQUIRED variables MUST be set to safe values before any production use.
#
# NEVER commit a real `.env` (it is git-ignored). NEVER put real secrets here.
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------

# Async SQLAlchemy connection string for the audit/governance database.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
#         (MSSQL via aioodbc is also supported: mssql+aioodbc://...)
# Required: YES for production (the default below uses throwaway dev credentials).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/synapse_ai_gateway

# SQLAlchemy connection-pool sizing. Integers. Optional.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Test connections before use (recovers from dropped DB connections). true|false. Optional.
DB_POOL_PRE_PING=true

# Echo every SQL statement to the log (verbose; dev debugging only). true|false. Optional.
DB_ECHO=false

# ----------------------------------------------------------------------------
# LLM BACKEND (Ollama / vLLM / any OpenAI-compatible endpoint)
# ----------------------------------------------------------------------------

# Base URL of the OpenAI-compatible inference endpoint, including the /v1 suffix.
# Examples:  Ollama -> http://localhost:11434/v1   |   vLLM -> http://localhost:8000/v1
# Note: this seeds the editable `vllm_url` setting on first run; afterwards it
# can be changed in the admin console (Settings -> Gateway Configuration).
# Optional.
VLLM_URL=http://localhost:11434/v1

# Optional cloud LLM endpoint for non-sensitive teams (data_classification =
# non_sensitive). Empty disables hybrid routing — all traffic stays on-prem.
# Example: https://api.openai.com/v1
CLOUD_VLLM_URL=

# Model assigned to seeded teams / used as the default. Must be a model the
# backend above can serve (e.g. "llama3.2", "meta-llama/Llama-3.1-8B-Instruct").
# Optional.
DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Seconds to wait for a chat-completion response from the LLM backend. Integer. Optional.
LLM_REQUEST_TIMEOUT_SEC=30

# Seconds to wait when listing available models (GET /admin/models). Float. Optional.
MODELS_FETCH_TIMEOUT_SEC=5.0

# ----------------------------------------------------------------------------
# OUTBOUND HTTP CLIENT (gateway -> LLM backend) — advanced tuning
# ----------------------------------------------------------------------------

# Connection / write / pool-acquire timeouts in seconds. Floats. Optional.
HTTP_CONNECT_TIMEOUT_SEC=5.0
HTTP_WRITE_TIMEOUT_SEC=10.0
HTTP_POOL_TIMEOUT_SEC=5.0

# Connection-pool limits for outbound requests. Integers. Optional.
HTTP_MAX_KEEPALIVE_CONNECTIONS=10
HTTP_MAX_CONNECTIONS=20

# ----------------------------------------------------------------------------
# AUTHENTICATION / JWT
# ----------------------------------------------------------------------------

# Initial password for the seeded `admin` superadmin account. The admin is
# forced to change this on first login, so this only needs to be memorable
# enough to get you to the change-password screen. The default `synapse` is
# fine for local dev — set a stronger value for any deployed instance.
# Required: YES (change before first run on anything beyond a laptop).
ADMIN_PASSWORD=synapse

# Secret key used to sign JWT access tokens. Use a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Required: YES (the app is insecure until this is changed).
JWT_SECRET=replace-with-a-64-char-random-hex-string

# JWT signing algorithm. Typically HS256. Optional.
JWT_ALGORITHM=HS256

# Access-token lifetime in hours. Integer. Optional.
ACCESS_TOKEN_EXPIRE_HOURS=8

# bcrypt cost factor for password hashing (higher = slower = safer). Integer 4-16. Optional.
BCRYPT_ROUNDS=12

# Minimum length enforced for new/changed passwords. Integer. Optional.
PASSWORD_MIN_LENGTH=12

# Length of auto-generated temporary passwords (admin reset). Integer. Optional.
TEMP_PASSWORD_LENGTH=16

# ----------------------------------------------------------------------------
# SECURITY POLICY DEFAULTS
# These seed the initial editable values in the `gateway_settings` table and
# act as runtime fallbacks. After first run, change them in the admin console.
# ----------------------------------------------------------------------------

# Failed logins before an account is temporarily locked. Integer. Optional.
MAX_FAILED_LOGINS=5

# Lockout duration in minutes after too many failed logins. Integer. Optional.
LOCKOUT_MINUTES=30

# Auto-disable accounts with no login for this many days (0 = never). Integer. Optional.
INACTIVITY_DISABLE_DAYS=90

# Minimum days between password changes (prevents cycling; 0 = disabled). Integer. Optional.
MIN_PASSWORD_AGE_DAYS=1

# Maximum password age in days before rotation is forced (0 = never). Integer. Optional.
MAX_PASSWORD_AGE_DAYS=90

# Reject reuse of the last N passwords (0 = disabled). Integer. Optional.
PASSWORD_HISTORY_COUNT=24

# Minutes before token expiry to warn the user in the UI. Integer. Optional.
SESSION_WARNING_MINUTES=2

# Enforce a single active session per user (newer login supersedes older). true|false. Optional.
SINGLE_SESSION_PER_USER=true

# ----------------------------------------------------------------------------
# RATE LIMITING + PROMPT DEFAULTS (seed initial gateway_settings)
# ----------------------------------------------------------------------------

# Default per-team request allowance within the window below. Integer. Optional.
DEFAULT_REQUESTS=10

# Default rate-limit window in seconds. Integer. Optional.
DEFAULT_WINDOW_SEC=60

# Default system prompt injected for teams that have none set. String. Optional.
DEFAULT_SYSTEM_PROMPT=You are a helpful AI assistant for YourOrg. Answer questions clearly and professionally. Do not discuss confidential bank policies or share sensitive information.

# ----------------------------------------------------------------------------
# DLP (Data Loss Prevention)
# ----------------------------------------------------------------------------

# Path to the JSON file holding the INITIAL DLP category definitions used to
# seed an empty database. JSON array of {"name","pattern","severity"} objects;
# severity is one of: Critical | High | Medium | Low.
# Default resolves to backend/dlp_patterns.json. Optional.
# DLP_PATTERNS_FILE=/absolute/path/to/dlp_patterns.json

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------

# Comma-separated list of allowed admin-console origins.
# Example: http://localhost:5173,http://192.0.2.5:5173
# Optional.
CORS_ORIGIN=http://localhost:5173

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------

# Root log level. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL.
# Logs are written to stdout/stderr (no log files) — container-friendly. Optional.
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# DEPLOYMENT (consumed by deploy/*.bat, not by the Python app directly)
# ----------------------------------------------------------------------------

# Port the backend (uvicorn) is launched on by the deploy scripts. Integer. Optional.
BACKEND_PORT=8080
