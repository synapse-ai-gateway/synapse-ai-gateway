# ============================================================================
# docker-compose overrides for the Synapse AI Gateway stack.
#
#   cp .env.example .env       # then edit
#   docker compose up --build  # auto-loads .env from this directory
#
# Anything left commented out falls back to the safe-for-laptop default baked
# into docker-compose.yml. For ANY non-laptop deployment, set the values in
# the REQUIRED block below explicitly.
#
# NOTE: this file is distinct from backend/.env.example. That one documents
# every variable the FastAPI process reads directly. This one documents only
# the subset that docker-compose substitutes into the stack at startup.
# ============================================================================

# ─── REQUIRED before exposing the stack beyond your laptop ───────────────────

# JWT signing secret. ANYONE who knows this can forge admin tokens.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=

# Initial password for the seeded 'admin' superadmin. The admin is forced to
# change it on first login, but pick a strong starting value.
# ADMIN_PASSWORD=

# Postgres credentials. The backend's DATABASE_URL is composed from these, so
# changing them here automatically keeps both services in sync.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=synapse_ai_gateway


# ─── OPTIONAL — only set if you want to override the laptop defaults ─────────

# Allowed admin-console origin (comma-separated for multiples).
# CORS_ORIGIN=http://localhost:5173

# LLM backend URL. Default reaches a host-installed Ollama via Docker Desktop's
# host bridge. Alternatives:
#   - Containerised Ollama:   http://ollama:11434/v1   (add an ollama service)
#   - vLLM:                    http://vllm:8000/v1
#   - OpenAI:                  https://api.openai.com/v1
# VLLM_URL=http://host.docker.internal:11434/v1

# Default model seeded for new teams. Must match a model your VLLM_URL serves.
# DEFAULT_MODEL=llama3.2:latest

# Seconds to wait for the LLM to respond. CPU cold-load can be 30+s; GPU < 5s.
# LLM_REQUEST_TIMEOUT_SEC=180

# Root log level: DEBUG | INFO | WARNING | ERROR | CRITICAL.
# LOG_LEVEL=INFO

# Where the SPA bundle sends API calls. BAKED INTO THE BUNDLE at build time —
# changing this requires a frontend rebuild (docker compose build frontend).
# VITE_GATEWAY_URL=http://localhost:8080
# VITE_USE_MOCK=false
