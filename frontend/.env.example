# ============================================================================
# Synapse AI Gateway — Frontend (admin console) configuration
# ----------------------------------------------------------------------------
# Copy to `.env`:  cp .env.example .env
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# Do NOT put secrets here — anything in a VITE_ variable ships to the client.
# ============================================================================

# Base URL of the backend gateway API the console talks to.
# Format: http(s)://HOST:PORT  (no trailing slash). Optional (defaults to localhost:8080).
VITE_GATEWAY_URL=http://localhost:8080

# Use the built-in mock API instead of a real backend. true|false.
# Set to false to talk to the live gateway. Optional (defaults to false in real builds).
VITE_USE_MOCK=false

# Dev server port for `npm run dev`. Integer. Optional (defaults to 5173).
VITE_DEV_PORT=5173

# Dev server bind address. 0.0.0.0 = all interfaces (reachable on LAN);
# 127.0.0.1 = localhost only. Optional (defaults to 0.0.0.0).
VITE_DEV_HOST=0.0.0.0
